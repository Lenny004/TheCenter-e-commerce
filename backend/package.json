{
  "name": "the-center-backend",
  "version": "1.0.0",
  "description": "The Center — API REST para plataforma e-commerce de ropa (Node.js + Express + Prisma + PostgreSQL)",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

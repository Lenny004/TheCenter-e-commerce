# Variables de entorno — The Center Backend
# Copiar este archivo como .env y completar los valores

# Base de datos PostgreSQL (coincide con docker-compose: db thecenter, usuario postgres)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/thecenter"

# Puerto del servidor
PORT=5000

# JWT — Clave secreta para tokens de autenticación
JWT_SECRET="CAMBIAR_POR_CLAVE_SEGURA_EN_PRODUCCION"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="CAMBIAR_POR_OTRA_CLAVE_SEGURA"
JWT_REFRESH_EXPIRES_IN="7d"

# Entorno de ejecución
NODE_ENV="development"

# CORS — Orígenes permitidos (separados por coma)
CORS_ORIGIN="http://localhost:4200"

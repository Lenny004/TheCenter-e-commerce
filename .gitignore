.pnp
.pnp.js

# ── Variables de entorno ──────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.*.local

# ── Build / Distribución ─────────────────────────────────────────────────────
dist/
build/
out/
*.tgz

# ── Angular ───────────────────────────────────────────────────────────────────
.angular/
.angular/cache/
.sass-cache/
tmp/
connect.lock

# ── Prisma ────────────────────────────────────────────────────────────────────
prisma/migrations/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── IDEs y Editores ──────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Sistema Operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Python (legacy) ──────────────────────────────────────────────────────────
